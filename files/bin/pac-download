#!/usr/bin/env -S pipx run
# /// script
# requires-python = ">=3.10"
# dependencies = ["requests ~= 2.20", "tqdm ~= 4.0"]
# ///

from __future__ import annotations
import argparse
import hashlib
import os
from pathlib import Path
import subprocess
import sys
import requests
from tqdm import tqdm


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("-d", "--directory", type=Path)
    parser.add_argument("--keep-on-error", action="store_true")
    parser.add_argument("-U", "--unpack", action="store_true")
    parser.add_argument("package", nargs="*")
    args = parser.parse_args()
    if not args.package:
        return
    r = subprocess.run(
        ["pacman", "-S", "--print-format=%n %r %f %s %h", "--", *args.package],
        stdout=subprocess.PIPE,
        text=True,
        encoding="utf-8",
    )
    if r.returncode != 0:
        sys.exit(r.returncode)
    if args.directory is not None:
        outdir = args.directory
        outdir.mkdir(parents=True, exist_ok=True)
    else:
        outdir = Path(".")
    with requests.Session() as s:
        for line in r.stdout.splitlines():
            pkgname, repo, fname, size_str, sha_hash = line.split()
            if pkgname not in args.package:
                # `pacman -S` also outputs info on dependencies
                continue
            size = int(size_str)
            outfile = outdir / fname
            print(f"Downloading {repo}/{pkgname} to {outfile} ...", file=sys.stderr)
            with s.get(
                f"https://archlinux.org/packages/{repo}/x86_64/{pkgname}/download/",
                stream=True,
            ) as r:
                r.raise_for_status()
                digester = hashlib.sha256()
                try:
                    with outfile.open("wb") as fp:
                        with tqdm(total=size) as t:
                            for chunk in r.iter_content(65535):
                                fp.write(chunk)
                                digester.update(chunk)
                                t.update(len(chunk))
                except Exception:
                    if not args.keep_on_error:
                        outfile.unlink(missing_ok=True)
                    raise
            got_digest = digester.hexdigest()
            if got_digest != sha_hash:
                if not args.keep_on_error:
                    outfile.unlink(missing_ok=True)
                sys.exit(
                    f"{sys.argv[0]}: Digest mismatch: expected {sha_hash}, got {got_digest}"
                )
            if args.unpack:
                unpack_dir = outdir / pkgname
                print(f"Unpacking {outfile} into {unpack_dir}/ ...")
                unpack_dir.mkdir(parents=True, exist_ok=True)
                r2 = subprocess.run(["tar", "--zstd", "-xf", outfile, "-C", unpack_dir])
                if r2.returncode != 0:
                    sys.exit(r2.returncode)


if __name__ == "__main__":
    main()
